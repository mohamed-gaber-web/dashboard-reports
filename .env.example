# Copy this file to `.env` (git-ignored). The dev API server (dev-api/server.js)
# and the serverless functions read these; secrets never reach the browser.

# D365 / Azure AD — client secret, injected server-side by /api/token.
AZURE_CLIENT_SECRET=your-azure-client-secret
# Optional overrides (defaults target the proven sandbox tenant):
# AZURE_TENANT_ID=26c58d65-b577-4f92-aed2-cec1395d146d
# AZURE_TOKEN_URL=https://login.microsoftonline.com/<tenant>/oauth2/v2.0/token

# Second D365 source — Shatat UAT (Sha_SerialTrans). Selected by client_id in /api/token.
AZURE_CLIENT_SECRET_SHATAT=your-shatat-client-secret
# AZURE_TENANT_ID_SHATAT=be88f713-a964-488f-89ef-00a04bc0f789

# AI Analyst — free key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: pin a model; otherwise a free-model fallback list is used.
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: local dev API port (default 3001; must match proxy.conf.js).
# DEV_API_PORT=3001
